{
  "name": "agentic-dataset-builder",
  "version": "0.2.1",
  "description": "Pure TypeScript agentic dataset builder for Pi, Codex, and Claude Code history",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/Dominic789654/agentic-dataset-builder",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dominic789654/agentic-dataset-builder.git"
  },
  "bugs": {
    "url": "https://github.com/Dominic789654/agentic-dataset-builder/issues"
  },
  "keywords": [
    "agentic",
    "dataset",
    "pi",
    "codex",
    "claude",
    "qwen",
    "zod",
    "parquet"
  ],
  "bin": {
    "agentic-dataset-builder": "./dist/cli.js"
  },
  "files": [
    "dist/cli.js",
    "dist/cli.d.ts",
    "dist/labeling.js",
    "dist/labeling.d.ts",
    "dist/parquet.js",
    "dist/parquet.d.ts",
    "dist/platform",
    "dist/schemas/qwen35.js",
    "dist/schemas/qwen35.d.ts",
    "dist/schemas/source.js",
    "dist/schemas/source.d.ts",
    "dist/sources/pi.js",
    "dist/sources/pi.d.ts",
    "dist/sources/codex.js",
    "dist/sources/codex.d.ts",
    "dist/sources/claude.js",
    "dist/sources/claude.d.ts",
    "dist/utils",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "pack:check": "npm pack --dry-run",
    "test": "vitest run"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "parquetjs-lite": "^0.8.7",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3"
  }
}
